# Selendra Network Configuration
ETHEREUM_JSONRPC_VARIANT=geth
ETHEREUM_JSONRPC_HTTP_URL=https://rpc.selendra.org/
ETHEREUM_JSONRPC_TRACE_URL=https://rpc.selendra.org/
ETHEREUM_JSONRPC_WS_URL=wss://rpc.selendra.org/
ETHEREUM_JSONRPC_TRANSPORT=http

# Database Configuration
DATABASE_URL=postgresql://blockscout:ceWb1MeLBEeOIfk65gU8EjF8@db:5432/blockscout

# Network Settings
CHAIN_ID=1961
COIN_NAME=Selendra Network
COIN=SEL
SECRET_KEY_BASE=56NtB48ear7+wMSf0IQuWDAAazhpb31qyc7GiyspBP2vh7t5zlCsF5QDv76chXeN

# Performance Configuration
POOL_SIZE=80
POOL_SIZE_API=10
ECTO_USE_SSL=false
HEART_BEAT_TIMEOUT=30

# Market Configuration (Disabled)
DISABLE_MARKET=true

# API Configuration
PORT=4000
API_V2_ENABLED=true
API_V1_READ_METHODS_DISABLED=false
API_V1_WRITE_METHODS_DISABLED=false
ADMIN_PANEL_ENABLED=false

# Features Configuration
MICROSERVICE_SC_VERIFIER_ENABLED=true
MICROSERVICE_SC_VERIFIER_URL=http://smart-contract-verifier:8050/
MICROSERVICE_SC_VERIFIER_TYPE=eth_bytecode_db
MICROSERVICE_VISUALIZE_SOL2UML_ENABLED=true
MICROSERVICE_VISUALIZE_SOL2UML_URL=http://visualizer:8050/
MICROSERVICE_SIG_PROVIDER_ENABLED=true
MICROSERVICE_SIG_PROVIDER_URL=http://sig-provider:8050/
MICROSERVICE_ACCOUNT_ABSTRACTION_URL=http://user-ops-indexer:8050/

# Indexer Configuration (Disabled internal tx fetcher - not supported by Selendra RPC)
INDEXER_DISABLE_PENDING_TRANSACTIONS_FETCHER=false
INDEXER_DISABLE_INTERNAL_TRANSACTIONS_FETCHER=true
TXS_STATS_DAYS_TO_COMPILE_AT_INIT=10
COIN_BALANCE_HISTORY_DAYS=90

# Security
RE_CAPTCHA_DISABLED=false
CHECKSUM_ADDRESS_HASHES=true

# Account Features
ACCOUNT_ENABLED=false
ACCOUNT_REDIS_URL=redis://redis-db:6379

# NFT Media Handler (Disabled to avoid permission issues)
NFT_MEDIA_HANDLER_ENABLED=false
NFT_MEDIA_HANDLER_REMOTE_DISPATCHER_NODE_MODE_ENABLED=false

# Release Configuration
RELEASE_NODE=producer@172.18.0.4
RELEASE_DISTRIBUTION=name
RELEASE_COOKIE=secret_cookie

# Health Monitoring
HEALTH_MONITOR_CHECK_INTERVAL=1m
HEALTH_MONITOR_BLOCKS_PERIOD=5m

# Cache Configuration
CACHE_BLOCK_COUNT_PERIOD=7200
CACHE_TXS_COUNT_PERIOD=7200
CACHE_ADDRESS_SUM_PERIOD=3600

# Disable unnecessary features for better performance
DISABLE_WEBAPP=false
DECODE_NOT_A_CONTRACT_CALLS=true