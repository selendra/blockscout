# Selendra Network Frontend Configuration
NEXT_PUBLIC_API_HOST=localhost
NEXT_PUBLIC_API_PROTOCOL=http
NEXT_PUBLIC_API_BASE_PATH=/
NEXT_PUBLIC_API_WEBSOCKET_PROTOCOL=ws

# Network Configuration
NEXT_PUBLIC_NETWORK_NAME=Selendra Network
NEXT_PUBLIC_NETWORK_SHORT_NAME=Selendra
NEXT_PUBLIC_NETWORK_ID=1961
NEXT_PUBLIC_NETWORK_CURRENCY_NAME=Selendra
NEXT_PUBLIC_NETWORK_CURRENCY_SYMBOL=SEL
NEXT_PUBLIC_NETWORK_CURRENCY_DECIMALS=18

# Application Configuration
NEXT_PUBLIC_APP_HOST=localhost
NEXT_PUBLIC_APP_PROTOCOL=http
NEXT_PUBLIC_IS_TESTNET=false

# Features Configuration
NEXT_PUBLIC_HOMEPAGE_CHARTS=['daily_txs']
NEXT_PUBLIC_VISUALIZE_API_HOST=http://localhost:8081

# Stats API
NEXT_PUBLIC_STATS_API_HOST=http://localhost:8082

# API Specification
NEXT_PUBLIC_API_SPEC_URL=https://raw.githubusercontent.com/blockscout/blockscout-api-v2-swagger/main/swagger.yaml
NEXT_PUBLIC_AD_BANNER_PROVIDER=none
NEXT_PUBLIC_AD_TEXT_PROVIDER=none
# Wallet Connect (Optional - for DApp interaction)
# NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_project_id_here